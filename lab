  provTitle.style.cssText = "font-family:'Barlow Condensed',sans-serif;font-size:38px;font-weight:400;letter-spacing:.01em;text-transform:uppercase;color:var(--text);line-height:1.1;margin-bottom:6px";
  provTitle.textContent = 'Proveedores';
  s1.appendChild(provTitle);

  const provGrid = document.createElement('div');
  provGrid.style.cssText = 'display:grid;grid-template-columns:repeat(auto-fit,minmax(185px,1fr));gap:12px';
  const PERIODS = ['T1 2024','T2 2024','T3 2024','T4 2024','T1 2025','T2 2025'];

  DATA.proveedores.groups.forEach(g => {
    const card = document.createElement('div');
    const fillColor = g.status==='ok'?'var(--ok-mid)':g.status==='warn'?'var(--warn-mid)':'var(--bad-mid)';
    const chipCls = g.status==='ok'?'pill pill-ok':g.status==='warn'?'pill pill-warn':'pill pill-bad';
    const chipLbl = g.status==='ok'?'Aceptable':g.status==='warn'?'En observación':'Crítico';
    const pctColor = g.status==='ok'?'var(--ok-mid)':g.status==='warn'?'var(--warn-mid)':'var(--bad-mid)';
    card.className = 'cat-card '+sc(g.status);
    card.style.cursor = 'pointer';
    const provRows = g.providers.map(p=>{
      const pl = p.evaluated && p.history.length ? p.history[p.history.length-1] : null;
      const ps = !p.evaluated?'none':pl>=75?'ok':pl>=50?'warn':'bad';
      const pc2 = pl!==null?(pl>=75?'var(--ok-mid)':pl>=50?'var(--warn-mid)':'var(--bad-mid)'):'var(--text-4)';
      return `<div style="display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:0.5px solid var(--border)">
        <span style="font-size:11px;color:var(--text-2);flex:1;margin-right:6px">${p.name}</span>
        <span style="font-family:'Fraunces',serif;font-size:13px;font-weight:600;color:${pc2}">${pl!==null?pl+'%':'—'}</span>
