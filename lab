function renderCatGrid(){
  const grid=document.getElementById('cat-grid');
  grid.innerHTML='';
  Object.entries(DATA).forEach(([key,cat])=>{
    if(key==='proveedores') return;
    const card=document.createElement('div');
    card.className='cat-card '+sc(cat.status);
    const pills=[];
    if(cat.counts.ok)   pills.push(`<span class="pill pill-ok">${cat.counts.ok} cumple${cat.counts.ok>1?'n':''}</span>`);
    if(cat.counts.warn) pills.push(`<span class="pill pill-warn">${cat.counts.warn} riesgo</span>`);
    if(cat.counts.bad)  pills.push(`<span class="pill pill-bad">${cat.counts.bad} fuera</span>`);
    if(cat.counts.none) pills.push(`<span class="pill pill-none">${cat.counts.none} s/datos</span>`);
    const fillColor=cat.status==='ok'?'var(--ok-mid)':cat.status==='warn'?'var(--warn-mid)':cat.status==='bad'?'var(--bad-mid)':'var(--teal)';
    card.innerHTML=`
      <div class="cat-top">
        <div class="cat-icon-wrap">${cat.icon}</div>
        <span class="${cc(cat.status)}">${sl(cat.status)}</span>
      </div>
      <div class="cat-name">${cat.name}</div>
      <div class="cat-counts">${pills.join('')}</div>
      <div class="cat-progress"><div class="cat-progress-fill" style="width:${cat.progress}%;background:${fillColor}"></div></div>
      <div class="cat-footer">
        <span class="cat-n">${cat.indicators.length} indicadores</span>
        <span class="cat-arrow">→</span>
      </div>`;
    card.onclick=()=>drillCat(key);
    grid.appendChild(card);
  });

  // Provider section
  const s1 = document.getElementById('s1');
  const divider = document.createElement('div');
  divider.style.cssText = 'height:0.5px;background:var(--border);margin:32px 0 24px';
