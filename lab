<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cuadro de Mando — P&P Laboratorios Padilla Peláez</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;0,9..144,900;1,9..144,300;1,9..144,700&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@300;400;500&family=Barlow+Condensed:wght@600;700;800&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
/* ── TOKENS ── */
:root {
  --teal:         #4F8D92;
  --teal-deep:    #2D6367;
  --teal-light:   #6AACB0;
  --teal-pale:    #C8E2E4;

  --ok:           #1E6B3C;
  --ok-mid:       #2E9E5A;
  --ok-bg:        #E6F5EC;
  --warn:         #7A4F00;
  --warn-mid:     #C47F00;
  --warn-bg:      #FFF4DF;
  --bad:          #8B1F1F;
  --bad-mid:      #C93535;
  --bad-bg:       #FDEAEA;

  --r:            10px;
  --r-lg:         16px;
  --transition:   .22s ease;
}

[data-theme="light"] {
  --bg:           #F3F4F5;
  --surface:      #FFFFFF;
  --surface2:     #ECEEF0;
  --border:       rgba(60,67,80,0.09);
  --border-md:    rgba(60,67,80,0.15);
  --text:         #1A1D22;
  --text-2:       #3C4350;
  --text-3:       #7A8290;
  --text-4:       #A8B0BB;
  --shadow:       0 1px 4px rgba(60,67,80,0.08), 0 0 0 0.5px rgba(60,67,80,0.06);
  --shadow-md:    0 4px 16px rgba(60,67,80,0.12), 0 0 0 0.5px rgba(60,67,80,0.07);
  --topbar-bg:    var(--teal-deep);
  --topbar-text:  rgba(255,255,255,0.9);
  --topbar-sub:   rgba(255,255,255,0.55);
  --chart-grid:   rgba(60,67,80,0.06);
  --chart-tick:   #9BA3AE;
  --none-bg:      #ECEEF0;
  --none-color:   #5A6270;
}

[data-theme="dark"] {
  --bg:           #111418;
  --surface:      #1C2128;
  --surface2:     #252B34;
  --border:       rgba(255,255,255,0.07);
  --border-md:    rgba(255,255,255,0.12);
  --text:         #E8ECF0;
  --text-2:       #B0BAC6;
  --text-3:       #6E7A88;
  --text-4:       #454F5C;
  --shadow:       0 1px 4px rgba(0,0,0,0.3), 0 0 0 0.5px rgba(255,255,255,0.05);
  --shadow-md:    0 6px 24px rgba(0,0,0,0.4), 0 0 0 0.5px rgba(255,255,255,0.06);
  --topbar-bg:    #0D1117;
  --topbar-text:  rgba(255,255,255,0.9);
  --topbar-sub:   rgba(255,255,255,0.4);
  --chart-grid:   rgba(255,255,255,0.05);
  --chart-tick:   #4E5A68;
  --none-bg:      #252B34;
  --none-color:   #6E7A88;
  --ok-bg:        rgba(46,158,90,0.15);
  --ok:           #52C97A;
  --warn-bg:      rgba(196,127,0,0.15);
  --warn:         #E5A020;
  --bad-bg:       rgba(201,53,53,0.15);
  --bad:          #E55555;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  font-size: 14px;
  line-height: 1.5;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  transition: background var(--transition), color var(--transition);
}

/* ── TOPBAR ── */
.topbar {
  background: var(--topbar-bg);
  padding: 0 28px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 16px rgba(0,0,0,0.25);
  transition: background var(--transition);
}
.topbar-left { display: flex; align-items: center; gap: 14px; min-width: 0; }
.topbar-logo { font-family: 'Barlow Condensed', sans-serif; font-size: 17px; font-weight: 400; letter-spacing: .04em; text-transform: uppercase; color: var(--topbar-text); white-space: nowrap; }
.topbar-logo span { color: var(--teal-pale); font-weight: 300; font-style: normal; }
.topbar-divider { width: 1px; height: 18px; background: rgba(255,255,255,0.18); flex-shrink: 0; }
.topbar-title { font-size: 12px; color: var(--topbar-sub); font-weight: 300; letter-spacing: .01em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.topbar-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
.topbar-badge {
  font-size: 10px; font-family: 'DM Mono', monospace; font-weight: 500;
  color: var(--teal-pale); background: rgba(255,255,255,0.08);
  border: 0.5px solid rgba(255,255,255,0.15);
  border-radius: 20px; padding: 4px 12px; letter-spacing: .05em;
  white-space: nowrap;
}

/* ── THEME TOGGLE ── */
.theme-toggle {
  width: 36px; height: 20px;
  background: rgba(255,255,255,0.12);
  border: 0.5px solid rgba(255,255,255,0.2);
  border-radius: 20px;
  cursor: pointer;
  position: relative;
  transition: background .2s;
  flex-shrink: 0;
}
.theme-toggle::after {
  content: '';
  position: absolute;
  top: 3px; left: 3px;
  width: 14px; height: 14px;
  background: rgba(255,255,255,0.9);
  border-radius: 50%;
  transition: transform .2s ease;
}
[data-theme="dark"] .theme-toggle::after { transform: translateX(16px); }
[data-theme="dark"] .theme-toggle { background: rgba(79,141,146,0.4); }
.toggle-label { font-size: 10px; color: var(--topbar-sub); font-family: 'DM Mono', monospace; white-space: nowrap; }

/* ── SHELL ── */
.shell { max-width: 1020px; margin: 0 auto; padding: 28px 24px 64px; }

/* ── BREADCRUMB ── */
.breadcrumb { display: flex; align-items: center; gap: 5px; margin-bottom: 22px; flex-wrap: wrap; }
.bc-item { font-size: 12px; color: var(--text-4); cursor: pointer; padding: 4px 8px; border-radius: 6px; transition: all .15s; font-weight: 400; }
.bc-item:hover { background: var(--surface); color: var(--teal); }
.bc-item.active { color: var(--text-2); font-weight: 500; pointer-events: none; }
.bc-item.clickable { color: var(--text-3); }
.bc-sep { color: var(--text-4); font-size: 11px; }

/* ── SCREENS ── */
.screen { display: none; animation: fadeUp .2s ease; }
.screen.active { display: block; }
@keyframes fadeUp { from { opacity:0; transform:translateY(5px); } to { opacity:1; transform:translateY(0); } }

/* ── PAGE TITLE ── */
.page-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 38px;
  font-weight: 400;
  letter-spacing: .01em;
  text-transform: uppercase;
  color: var(--text);
  letter-spacing: -.5px;
  line-height: 1.1;
  margin-bottom: 6px;
}
.page-subtitle { font-size: 13px; color: var(--text-3); font-weight: 300; margin-bottom: 28px; }

/* ── KPI ROW ── */
.kpi-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(145px,1fr)); gap: 10px; margin-bottom: 32px; }
.kpi {
  background: var(--surface);
  border-radius: var(--r);
  padding: 18px 18px 16px;
  box-shadow: var(--shadow);
  border-top: 3px solid var(--border);
  transition: background var(--transition), box-shadow var(--transition);
  position: relative;
  overflow: hidden;
}
.kpi.accent { border-top-color: var(--teal); }
.kpi.ok     { border-top-color: var(--ok-mid); }
.kpi.warn   { border-top-color: var(--warn-mid); }
.kpi.bad    { border-top-color: var(--bad-mid); }
.kpi-lbl {
  font-size: 11px; font-family: 'DM Sans', sans-serif; font-weight: 700;
  color: var(--text-3); letter-spacing: .04em; text-transform: uppercase; margin-bottom: 10px;
}
.kpi-val {
  font-family: 'Fraunces', serif;
  font-size: 32px; font-weight: 900;
  color: var(--text); letter-spacing: -1px; line-height: 1;
}
.kpi-val.col-teal { color: var(--teal); }
.kpi-val.col-ok   { color: var(--ok-mid); }
.kpi-val.col-warn { color: var(--warn-mid); }
.kpi-val.col-bad  { color: var(--bad-mid); }
.kpi-sub { font-size: 11px; color: var(--text-4); margin-top: 6px; font-weight: 300; line-height: 1.4; }

/* ── STATUS LEGEND ── */
.legend-strip { display: flex; gap: 20px; flex-wrap: wrap; margin-bottom: 20px; }
.legend-item { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--text-3); font-family: 'DM Mono', monospace; }
.legend-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }

/* ── CATEGORY GRID ── */
.cat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(185px,1fr)); gap: 12px; }
.cat-card {
  background: var(--surface);
  border-radius: var(--r-lg);
  padding: 20px;
  cursor: pointer;
  box-shadow: var(--shadow);
  transition: box-shadow var(--transition), transform .14s, background var(--transition);
  position: relative;
  overflow: hidden;
  border: 0.5px solid var(--border);
}
.cat-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
}
.cat-card.ok::before   { background: linear-gradient(90deg, var(--ok-mid), #52C97A); }
.cat-card.warn::before { background: linear-gradient(90deg, var(--warn-mid), #E5A020); }
.cat-card.bad::before  { background: linear-gradient(90deg, var(--bad-mid), #E55555); }
.cat-card.none::before { background: linear-gradient(90deg, var(--teal), var(--teal-light)); }
.cat-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }

.cat-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 14px; }
.cat-icon-wrap {
  width: 34px; height: 34px; border-radius: 8px;
  background: var(--surface2);
  display: flex; align-items: center; justify-content: center;
  font-size: 15px; color: var(--teal);
  transition: background var(--transition);
}
.status-chip {
  font-size: 10px; font-family: 'DM Mono', monospace; font-weight: 500;
  padding: 3px 8px; border-radius: 20px; letter-spacing: .02em;
}
.chip-ok   { background: var(--ok-bg);   color: var(--ok);   }
.chip-warn { background: var(--warn-bg); color: var(--warn); }
.chip-bad  { background: var(--bad-bg);  color: var(--bad);  }
.chip-none { background: var(--none-bg); color: var(--teal); }

.cat-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 17px; font-weight: 700;
  letter-spacing: .03em; text-transform: uppercase;
  color: var(--text); margin-bottom: 10px; letter-spacing: -.2px;
}
.cat-counts { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 14px; }
.pill {
  font-size: 10px; font-family: 'DM Mono', monospace;
  padding: 3px 8px; border-radius: 20px; font-weight: 400; letter-spacing: .02em;
}
.pill-ok   { background: var(--ok-bg);   color: var(--ok);   }
.pill-warn { background: var(--warn-bg); color: var(--warn); }
.pill-bad  { background: var(--bad-bg);  color: var(--bad);  }
.pill-none { background: var(--none-bg); color: var(--none-color); }

.cat-progress { height: 3px; background: var(--surface2); border-radius: 2px; overflow: hidden; margin-bottom: 12px; }
.cat-progress-fill { height: 100%; border-radius: 2px; }
.cat-footer { display: flex; align-items: center; justify-content: space-between; }
.cat-n { font-size: 11px; color: var(--text-4); font-weight: 300; }
.cat-arrow { font-size: 13px; color: var(--teal); transition: transform .15s; font-weight: 600; }
.cat-card:hover .cat-arrow { transform: translateX(3px); }

/* ── SECTION HEADER ── */
.section-hdr { display: flex; align-items: center; gap: 12px; margin-bottom: 22px; flex-wrap: wrap; }
.back-btn {
  display: flex; align-items: center; gap: 6px;
  font-size: 12px; font-weight: 500; color: var(--teal);
  background: var(--surface); border: 0.5px solid var(--border-md);
  border-radius: 20px; padding: 6px 14px; cursor: pointer;
  box-shadow: var(--shadow); transition: all .15s;
}
.back-btn:hover { background: var(--surface2); }
.section-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 28px; font-weight: 800; color: var(--text); letter-spacing: .02em; text-transform: uppercase;
}

/* ── INDICATOR GRID ── */
.ind-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(185px,1fr)); gap: 10px; margin-bottom: 20px; }
.ind-card {
  background: var(--surface);
  border-radius: var(--r);
  padding: 16px;
  cursor: pointer;
  box-shadow: var(--shadow);
  border-left: 3px solid var(--border);
  transition: box-shadow .15s, transform .12s, background var(--transition);
}
.ind-card.ok   { border-left-color: var(--ok-mid); }
.ind-card.warn { border-left-color: var(--warn-mid); }
.ind-card.bad  { border-left-color: var(--bad-mid); }
.ind-card.none { border-left-color: var(--teal); }
.ind-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }

.ind-name { font-size: 12px; font-weight: 600; color: var(--text); margin-bottom: 12px; line-height: 1.4; min-height: 34px; letter-spacing: -.1px; }
.ind-data-row { display: flex; justify-content: space-between; align-items: baseline; padding: 5px 0; border-bottom: 0.5px solid var(--border); }
.ind-data-row:last-of-type { border-bottom: none; }
.ind-lbl { font-size: 10px; font-family: 'DM Mono', monospace; color: var(--text-4); letter-spacing: .04em; text-transform: uppercase; }
.ind-val { font-family: 'Fraunces', serif; font-size: 15px; font-weight: 600; color: var(--text); letter-spacing: -.2px; }
.ind-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 10px; padding-top: 10px; border-top: 0.5px solid var(--border); }
.trend { font-size: 12px; font-family: 'DM Mono', monospace; font-weight: 500; }
.trend.up { color: var(--ok-mid); }
.trend.dn { color: var(--bad-mid); }
.trend.eq { color: var(--text-4); }

/* ── PANELS ── */
.panel {
  background: var(--surface);
  border-radius: var(--r-lg);
  padding: 22px;
  margin-bottom: 14px;
  box-shadow: var(--shadow);
  border: 0.5px solid var(--border);
  transition: background var(--transition);
}
.panel-label {
  font-size: 10px; font-family: 'DM Mono', monospace; font-weight: 500;
  color: var(--text-4); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 16px;
}

/* ── DETAIL KPI ── */
.detail-kpi { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; margin-bottom: 14px; }
.detail-kpi .kpi-val { font-size: 26px; }

/* ── CHART ── */
.chart-legend { display: flex; gap: 18px; margin-bottom: 12px; flex-wrap: wrap; }
.chart-legend-item { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--text-3); font-family: 'DM Mono', monospace; }
.chart-legend-sq { width: 14px; height: 3px; border-radius: 2px; }

/* ── OBS ── */
.obs-item { display: flex; gap: 12px; padding: 10px 0; border-bottom: 0.5px solid var(--border); font-size: 13px; color: var(--text-2); line-height: 1.5; font-weight: 300; }
.obs-item:last-child { border-bottom: none; }
.obs-marker { width: 4px; min-width: 4px; height: 4px; border-radius: 50%; margin-top: 7px; flex-shrink: 0; }

/* ── DIMENSIONS ── */
.dim-section { margin-top: 20px; padding-top: 20px; border-top: 0.5px solid var(--border); }
.dim-row { margin-bottom: 12px; }
.dim-hd { display: flex; justify-content: space-between; align-items: baseline; font-size: 12px; margin-bottom: 6px; }
.dim-name-t { color: var(--text-3); font-weight: 400; }
.dim-pct { font-family: 'Fraunces', serif; font-weight: 600; font-size: 13px; letter-spacing: -.2px; }
.bar-bg { height: 5px; background: var(--surface2); border-radius: 3px; overflow: hidden; }
.bar-fg { height: 5px; border-radius: 3px; transition: width .5s ease; }

/* ── REC PANEL ── */
.rec-panel { background: var(--surface2); border-radius: var(--r); padding: 16px; border: 0.5px solid var(--border); }
.rec-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(155px,1fr)); gap: 8px; margin-top: 10px; }
.rec-item { background: var(--surface); border: 0.5px solid var(--border); border-radius: var(--r); padding: 12px 14px; font-size: 12px; font-weight: 500; color: var(--text-2); line-height: 1.5; }
.rec-item span { display: block; font-size: 11px; color: var(--text-4); font-weight: 300; margin-top: 2px; }

/* ── FOOTER ── */
.footer { margin-top: 48px; padding-top: 20px; border-top: 0.5px solid var(--border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; }
.footer-txt { font-size: 11px; color: var(--text-4); font-family: 'DM Mono', monospace; }
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-left">
    <div class="topbar-logo">P&P <span>Laboratorios Padilla Peláez</span></div>
    <div class="topbar-divider"></div>
    <div class="topbar-title">Cuadro de mando · ISO 9001</div>
  </div>
  <div class="topbar-right">
    <span class="topbar-badge" id="topbar-period"></span>
    <span class="toggle-label" id="toggle-lbl">Oscuro</span>
    <div class="theme-toggle" onclick="toggleTheme()" role="switch" aria-label="Alternar modo claro/oscuro"></div>
  </div>
</div>

<div class="shell">

  <div class="breadcrumb">
    <span class="bc-item active" id="bc1" onclick="goTo(1)">Resumen ejecutivo</span>
    <span class="bc-sep" id="bcsep1" style="display:none">›</span>
    <span class="bc-item clickable" id="bc2" style="display:none" onclick="goTo(2)"></span>
    <span class="bc-sep" id="bcsep2" style="display:none">›</span>
    <span class="bc-item active" id="bc3" style="display:none"></span>
  </div>

  <!-- ══════ NIVEL 1 ══════ -->
  <div class="screen active" id="s1">
    <div class="page-title">Cuadro de mando</div>
    <div class="page-subtitle">Sistema de gestión de calidad · Revisión por la dirección</div>

    <div class="kpi-row">
      <div class="kpi accent">
        <div class="kpi-lbl">Indicadores totales</div>
        <div class="kpi-val col-teal">20</div>
        <div class="kpi-sub">5 perspectivas estratégicas</div>
      </div>
      <div class="kpi ok">
        <div class="kpi-lbl">Cumplen</div>
        <div class="kpi-val col-ok">—</div>
        <div class="kpi-sub">Pendiente de carga</div>
      </div>
      <div class="kpi warn">
        <div class="kpi-lbl">En riesgo</div>
        <div class="kpi-val col-warn">—</div>
        <div class="kpi-sub">Pendiente de carga</div>
      </div>
      <div class="kpi bad">
        <div class="kpi-lbl">Fuera de meta</div>
        <div class="kpi-val col-bad">1</div>
        <div class="kpi-sub">Satisfacción del paciente</div>
      </div>
    </div>

    <div class="legend-strip">
      <span class="legend-item"><span class="legend-dot" style="background:var(--ok-mid)"></span>Cumple</span>
      <span class="legend-item"><span class="legend-dot" style="background:var(--warn-mid)"></span>En riesgo</span>
      <span class="legend-item"><span class="legend-dot" style="background:var(--bad-mid)"></span>Fuera de meta</span>
      <span class="legend-item"><span class="legend-dot" style="background:var(--teal)"></span>Sin datos</span>
    </div>

    <div class="cat-grid" id="cat-grid"></div>
  </div>

  <!-- ══════ NIVEL 2 ══════ -->
  <div class="screen" id="s2">
    <div class="section-hdr">
      <button class="back-btn" onclick="goTo(1)">← Resumen</button>
      <div>
        <div class="section-title" id="cat-title2"></div>
      </div>
      <span class="pill" id="cat-badge2"></span>
    </div>
    <div class="ind-grid" id="ind-grid"></div>
    <div class="rec-panel">
      <div class="panel-label">Gráficos recomendados para esta perspectiva</div>
      <div class="rec-grid" id="rec-grid"></div>
    </div>
  </div>

  <!-- ══════ NIVEL 3 ══════ -->
  <div class="screen" id="s3">
    <div class="section-hdr">
      <button class="back-btn" onclick="goTo(2)">← <span id="back-cat-lbl"></span></button>
      <div>
        <div class="section-title" id="ind-detail-name"></div>
        <div style="font-size:12px;color:var(--text-4);margin-top:3px;font-family:'DM Mono',monospace;font-weight:300" id="ind-detail-sub"></div>
      </div>
    </div>

    <div class="detail-kpi">
      <div class="kpi accent">
        <div class="kpi-lbl">Meta</div>
        <div class="kpi-val col-teal" id="d-meta"></div>
        <div class="kpi-sub" id="d-crit"></div>
      </div>
      <div class="kpi">
        <div class="kpi-lbl">Último resultado</div>
        <div class="kpi-val" id="d-ult"></div>
        <div class="kpi-sub" id="d-est"></div>
