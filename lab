  currentCat = 'proveedores';
  document.getElementById('cat-title2').textContent = group.name;
  document.getElementById('back-cat-lbl').textContent = group.name;
  const badge = document.getElementById('cat-badge2');
  const chipLbl = group.status==='ok'?'Aceptable':group.status==='warn'?'En observación':'Crítico';
  badge.textContent = group.status==='none'?'Sin evaluar':chipLbl;
  badge.className = 'pill pill-'+sc(group.status);

  provMiniCharts.forEach(c=>c.destroy());
  provMiniCharts=[];

  const grid = document.getElementById('ind-grid');
  grid.innerHTML='';
  grid.style.gridTemplateColumns = 'repeat(auto-fit,minmax(220px,1fr))';

  const PERIODS = ['T1 2024','T2 2024','T3 2024','T4 2024','T1 2025','T2 2025'];

  group.providers.forEach((p,i) => {
    const last = p.evaluated && p.history.length ? p.history[p.history.length-1] : null;
    const pstatus = !p.evaluated?'none':last>=75?'ok':last>=50?'warn':'bad';
    const pctColor = !p.evaluated?'var(--text-3)':last>=75?'var(--ok-mid)':last>=50?'var(--warn-mid)':'var(--bad-mid)';
    const card = document.createElement('div');
    card.className='ind-card '+pstatus;

    const critHtml = p.criteria.map(c=>`
      <div style="margin-bottom:8px">
        <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:4px">
          <span style="font-size:11px;color:var(--text-3);line-height:1.3;flex:1;margin-right:6px">${c.name}</span>
          <span style="font-size:11px;font-family:'DM Mono',monospace;font-weight:500;color:${c.pct!==null?'var(--text)':'var(--text-4)'}">${c.pct!==null?c.pct+'%':'—'}</span>
        </div>
        <div style="height:4px;background:var(--surface2);border-radius:2px;overflow:hidden">
          ${c.pct!==null?`<div style="height:4px;border-radius:2px;width:${c.pct}%;background:${c.pct>=75?'var(--ok-mid)':c.pct>=50?'var(--warn-mid)':'var(--bad-mid)'}"></div>`:''}
        </div>
      </div>`).join('');

    const chartId = 'prov-chart-'+i;
    const respBadge = p.resp ? `<span style="font-size:10px;font-family:'DM Mono',monospace;color:var(--text-4)">Resp.: ${p.resp}</span>` : '';
    const acumVal = last !== null ? last+'%' : '—';

    card.innerHTML = `
      <div class="ind-name">${p.name}</div>
      <div class="ind-data-row">
        <span class="ind-lbl">Meta</span>
        <span class="ind-val">≥ 75%</span>
      </div>
      <div class="ind-data-row">
        <span class="ind-lbl">Último</span>
        <span class="ind-val" style="color:${pctColor}">${last!==null?last+'%':'—'}</span>
      </div>
      <div class="ind-data-row">
        <span class="ind-lbl">Acumulado</span>
        <span class="ind-val">${acumVal}</span>
      </div>
      <div class="ind-footer">
        <span style="font-size:11px;font-family:'DM Mono',monospace;color:var(--text-4)">${p.resp?'Resp.: '+p.resp:''}</span>
        <span class="pill pill-${pstatus}">${!p.evaluated?'Sin evaluar':last>=75?'Aceptable':last>=50?'En observación':'Crítico'}</span>
      </div>
      <div style="margin-top:10px;padding-top:10px;border-top:0.5px solid var(--border)">
        <div style="font-size:10px;font-family:'DM Mono',monospace;font-weight:500;color:var(--text-4);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">Evolución histórica</div>
        ${p.evaluated
          ? `<div style="position:relative;width:100%;height:70px"><canvas id="${chartId}" role="img" aria-label="Evolución de ${p.name}"></canvas></div>`
          : `<div style="height:70px;display:flex;align-items:center;justify-content:center;background:var(--surface2);border-radius:6px;font-size:11px;color:var(--text-4);font-family:'DM Mono',monospace">Sin datos aún</div>`
        }
      </div>
      ${p.evaluated ? `
      <div style="margin-top:12px;padding-top:12px;border-top:0.5px solid var(--border)">
        <div style="font-size:10px;font-family:'DM Mono',monospace;font-weight:500;color:var(--text-4);letter-spacing:.08em;text-transform:uppercase;margin-bottom:10px">Por criterio</div>
        ${critHtml}
      </div>` : ''}`;

    card.style.cursor = 'default';
    grid.appendChild(card);

    if(p.evaluated && p.history.length >= 1){
      setTimeout(()=>{
        const el = document.getElementById(chartId);
        if(!el) return;
        const {grid:gc,tick:tc} = getChartColors();
        const c = new Chart(el,{
          type:'line',
          data:{
            labels:p.history.length===1?['Evaluación 1']:PERIODS.slice(-p.history.length),
            datasets:[
              {data:p.history,borderColor:'#4F8D92',backgroundColor:'rgba(79,141,146,0.08)',fill:true,tension:.35,pointRadius:3,pointBackgroundColor:'#4F8D92',borderWidth:1.5},
              {data:p.history.map(()=>75),borderColor:'#C93535',backgroundColor:'transparent',borderDash:[3,3],pointRadius:0,borderWidth:1}
            ]
          },
          options:{
            responsive:true,maintainAspectRatio:false,
            plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>c.datasetIndex===0?c.parsed.y+'%':''}}},
            scales:{
              x:{ticks:{color:tc,font:{size:9},maxRotation:0,autoSkip:true,maxTicksLimit:3},grid:{color:gc}},
              y:{min:0,max:110,ticks:{color:tc,font:{size:9},callback:v=>v+'%',maxTicksLimit:3},grid:{color:gc}}
            }
          }
        });
        provMiniCharts.push(c);
      },80);
    }
  });

  const recGrid = document.getElementById('rec-grid');
  recGrid.innerHTML='';
  DATA.proveedores.rec.forEach(r=>{
    recGrid.innerHTML+=`<div class="rec-item">${r.label}<span>${r.sub}</span></div>`;
  });
  goTo(2);
}

// ── NIVEL 2 ──
let indMiniCharts=[];
function drillCat(key){
  currentCat=key;
  const cat=DATA[key];
  document.getElementById('cat-title2').textContent=cat.name;
  document.getElementById('back-cat-lbl').textContent=cat.name;
  const badge=document.getElementById('cat-badge2');
  badge.textContent=sl(cat.status); badge.className=pc(cat.status);

  indMiniCharts.forEach(c=>c.destroy());
  indMiniCharts=[];

  const grid=document.getElementById('ind-grid');
  grid.innerHTML='';
  grid.style.gridTemplateColumns='repeat(auto-fit,minmax(200px,1fr))';

  cat.indicators.forEach((ind,i)=>{
    const hasData = ind.chartData && ind.chartData.some(v=>v!==null);
    const chartId = 'ind-mini-'+i;
    const card=document.createElement('div');
    card.className='ind-card '+sc(ind.status);
    card.innerHTML=`
      <div class="ind-name">${ind.name}</div>
      <div class="ind-data-row"><span class="ind-lbl">Meta</span><span class="ind-val">${ind.meta}</span></div>
      <div class="ind-data-row"><span class="ind-lbl">Último</span><span class="ind-val" style="color:${scol(ind.status)}">${ind.ultimo}</span></div>
      <div class="ind-data-row"><span class="ind-lbl">Acumulado</span><span class="ind-val">${ind.acum}</span></div>
      <div class="ind-footer">
        <span class="${tc2(ind.trend)}">${ts(ind.trend)}</span>
        <span class="${pc(ind.status)}">${sl(ind.status)}</span>
      </div>
      <div style="margin-top:10px;padding-top:10px;border-top:0.5px solid var(--border)">
        <div style="font-size:10px;font-family:'DM Mono',monospace;font-weight:500;color:var(--text-4);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">Evolución</div>
        ${hasData
          ? `<div style="position:relative;width:100%;height:70px"><canvas id="${chartId}" role="img" aria-label="Evolución de ${ind.name}"></canvas></div>`
          : `<div style="height:70px;display:flex;align-items:center;justify-content:center;background:var(--surface2);border-radius:6px;font-size:11px;color:var(--text-4);font-family:'DM Mono',monospace">Sin datos aún</div>`
        }
      </div>`;
    card.onclick=()=>drillInd(i);
    grid.appendChild(card);

    if(hasData){
      setTimeout(()=>{
        const el=document.getElementById(chartId);
        if(!el) return;
        const {grid:gc,tick:tc}=getChartColors();
        const hasMeta=ind.chartMeta!==null;
        const datasets=[{
          data:ind.chartData,
          borderColor:'#4F8D92',
          backgroundColor:'rgba(79,141,146,0.08)',
          fill:true, tension:.35,
          pointRadius:2, pointBackgroundColor:'#4F8D92',
          borderWidth:1.5, spanGaps:false
        }];
        if(hasMeta) datasets.push({
          data:ind.chartLabels.map(()=>ind.chartMeta),
          borderColor:'#C93535',
          backgroundColor:'transparent',
          borderDash:[3,3], pointRadius:0, borderWidth:1
        });
        const c=new Chart(el,{
          type:'line',
          data:{labels:ind.chartLabels, datasets},
          options:{
            responsive:true, maintainAspectRatio:false,
            plugins:{legend:{display:false}, tooltip:{callbacks:{label:c=>c.datasetIndex===0?c.parsed.y!==null?c.parsed.y.toFixed(1)+(hasMeta?'%':''):'—':''}}},
            scales:{
              x:{ticks:{color:tc,font:{size:9},maxRotation:0,autoSkip:true,maxTicksLimit:4},grid:{color:gc}},
              y:{ticks:{color:tc,font:{size:9},callback:v=>v+(hasMeta?'%':''),maxTicksLimit:3},grid:{color:gc},
                min:hasMeta?Math.min(80,...ind.chartData.filter(v=>v!==null).map(v=>v-5)):undefined}
            }
          }
        });
        indMiniCharts.push(c);
      },80);
    }
  });

  const recGrid=document.getElementById('rec-grid');
  recGrid.innerHTML='';
  cat.rec.forEach(r=>{
    recGrid.innerHTML+=`<div class="rec-item">${r.label}<span>${r.sub}</span></div>`;
  });
  goTo(2);
}

// ── NIVEL 3 ──
function drillInd(idx){
  currentInd=idx;
  const ind=DATA[currentCat].indicators[idx];
  document.getElementById('ind-detail-name').textContent=ind.name;
  document.getElementById('ind-detail-sub').textContent=DATA[currentCat].name+' · Frecuencia: '+ind.frec;
  document.getElementById('d-meta').textContent=ind.meta;
  document.getElementById('d-crit').textContent=ind.criterio;
  document.getElementById('d-ult').textContent=ind.ultimo;
  document.getElementById('d-ult').style.color=scol(ind.status);
  document.getElementById('d-est').textContent=sl(ind.status);
  document.getElementById('d-acum').textContent=ind.acum;
  document.getElementById('d-tend').textContent='Tendencia '+ts(ind.trend);
  const obsList=document.getElementById('obs-list');
  obsList.innerHTML='';
  ind.obs.forEach(o=>{
    obsList.innerHTML+=`<div class="obs-item"><div class="obs-marker" style="background:${o.color}"></div><span>${o.text}</span></div>`;
  });
  const dimSection=document.getElementById('dim-section');
  const dimList=document.getElementById('dim-list');
  if(ind.dims&&ind.dims.length){
    dimSection.style.display='block'; dimList.innerHTML='';
    ind.dims.forEach(d=>{
      dimList.innerHTML+=`
        <div class="dim-row">
          <div class="dim-hd">
            <span class="dim-name-t">${d.name}</span>
            <span class="dim-pct" style="color:${d.trendColor}">${d.pct.toFixed(1)}% ${d.trend}</span>
          </div>
          <div class="bar-bg"><div class="bar-fg" style="width:${d.pct}%;background:${d.color}"></div></div>
        </div>`;
    });
  } else { dimSection.style.display='none'; }
  rebuildChart(currentCat, idx);
  goTo(3);
}

function rebuildChart(catKey, idx){
  if(chartInst){chartInst.destroy();chartInst=null;}
  const ind=DATA[catKey].indicators[idx];
  const {grid,tick}=getChartColors();
  const hasMeta=ind.chartMeta!==null;
  setTimeout(()=>{
    const ctx=document.getElementById('detailChart');
    const datasets=[{
      label:'Resultado', data:ind.chartData,
      borderColor:'#4F8D92', backgroundColor:'rgba(79,141,146,0.08)',
      fill:true, tension:.35, pointRadius:5, pointBackgroundColor:'#4F8D92',
      borderWidth:2, spanGaps:false
    }];
    if(hasMeta) datasets.push({
      label:'Meta', data:ind.chartLabels.map(()=>ind.chartMeta),
      borderColor:'#C93535', backgroundColor:'transparent',
      borderDash:[5,4], pointRadius:0, borderWidth:1.5
    });
    chartInst=new Chart(ctx,{
      type:'line',
      data:{labels:ind.chartLabels,datasets},
      options:{
        responsive:true, maintainAspectRatio:false,
        plugins:{legend:{display:false}, tooltip:{callbacks:{label:c=>c.dataset.label+': '+(c.parsed.y!==null?c.parsed.y.toFixed(1)+(hasMeta?'%':''):'—')}}},
        scales:{
          x:{ticks:{color:tick,font:{size:11,family:"'DM Mono',monospace"}},grid:{color:grid}},
          y:{ticks:{color:tick,font:{size:11,family:"'DM Mono',monospace"},callback:v=>v+(hasMeta?'%':'')},
            grid:{color:grid},
            min:hasMeta?Math.min(80,...ind.chartData.filter(v=>v!==null).map(v=>v-5)):undefined}
        }
      }
    });
  },50);
}

// ── INIT ──
function init(){
  const now=new Date();
  const meses=['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  document.getElementById('topbar-period').textContent=meses[now.getMonth()]+' '+now.getFullYear();
  document.getElementById('footer-date').textContent='Generado el '+now.toLocaleDateString('es-AR',{day:'2-digit',month:'long',year:'numeric'});
  renderCatGrid();
}
init();
</script>
</body>
</html>
