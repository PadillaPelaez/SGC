function toggleTheme(){
  const html=document.documentElement;
  const isDark=html.getAttribute('data-theme')==='dark';
  html.setAttribute('data-theme', isDark?'light':'dark');
  document.getElementById('toggle-lbl').textContent=isDark?'Oscuro':'Claro';
  if(chartInst){ rebuildChart(currentCat,currentInd); }
}

function getChartColors(){
  const dark=document.documentElement.getAttribute('data-theme')==='dark';
  return {
    grid: dark?'rgba(255,255,255,0.05)':'rgba(60,67,80,0.06)',
    tick: dark?'#4E5A68':'#9BA3AE'
  };
}

// ── NAVEGACIÓN ──
function goTo(n){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById('s'+n).classList.add('active');
  updateBc(n);
}

function updateBc(n){
  const bc1=document.getElementById('bc1');
  const bc2=document.getElementById('bc2');
  const bc3=document.getElementById('bc3');
  const s1=document.getElementById('bcsep1');
  const s2=document.getElementById('bcsep2');
  bc1.className='bc-item'+(n===1?' active':' clickable');
  if(n===1){[bc2,s1,bc3,s2].forEach(e=>e.style.display='none');return;}
  s1.style.display='inline'; bc2.style.display='inline';
  bc2.textContent=currentCat?DATA[currentCat].name:'';
  bc2.className='bc-item'+(n===2?' active':' clickable');
  if(n===2){[bc3,s2].forEach(e=>e.style.display='none');return;}
  s2.style.display='inline'; bc3.style.display='inline';
  bc3.textContent=currentInd!==null?DATA[currentCat].indicators[currentInd].name:'';
  bc3.className='bc-item active';
}

